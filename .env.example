# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ─── MySQL ───────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=finance_dashboard

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_a_strong_random_secret_64chars
JWT_REFRESH_SECRET=replace_with_a_different_strong_random_secret_64chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
